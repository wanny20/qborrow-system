rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       BASIC HELPERS
    ========================= */

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasUserDoc() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDoc().data;
    }

    function role() {
      return hasUserDoc() ? userData().role : "";
    }

    function isBorrower() {
      return role() == "borrower";
    }

    function isSuperAdmin() {
      return role() == "superAdmin";
    }

    function isCategoryAdmin() {
      return role() == "categoryAdmin";
    }

    function isAdmin() {
      return role() in ["superAdmin", "categoryAdmin"];
    }

    function isSchoolClosed() {
      return exists(/databases/$(database)/documents/systemSettings/schoolStatus) &&
        get(/databases/$(database)/documents/systemSettings/schoolStatus).data.isSchoolClosed == true;
    }

    function isSystemSuspended() {
      return exists(/databases/$(database)/documents/systemSettings/schoolStatus) &&
        get(/databases/$(database)/documents/systemSettings/schoolStatus).data.isSystemSuspended == true;
    }

    function isBorrowingUnavailable() {
      return isSchoolClosed() || isSystemSuspended();
    }

    function assignedCategories() {
      return userData().assignedCategories is list
        ? userData().assignedCategories
        : [];
    }

    function getCategoryId(data) {
      return data.categoryId != null
        ? data.categoryId
        : data.category != null
          ? data.category
          : "";
    }

    function getCategoryName(data) {
      return data.categoryName != null
        ? data.categoryName
        : data.category != null
          ? data.category
          : "";
    }

    function adminCanAccessCategory(data) {
      return isSuperAdmin() ||
        (
          isCategoryAdmin() &&
          (
            getCategoryId(data) in assignedCategories() ||
            getCategoryName(data) in assignedCategories()
          )
        );
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function hasOnlyChangedFields(fields) {
      return changedKeys().hasOnly(fields);
    }

    /* =========================
       USERS
    ========================= */

    match /users/{userId} {
      allow read: if signedIn() && (
        isOwner(userId) ||
        isAdmin()
      );

      allow create: if isSuperAdmin();

      allow update: if isSuperAdmin();

      allow update: if isOwner(userId) &&
        hasOnlyChangedFields([
          "fullName",
          "photoURL",
          "photoPath",
          "themeMode",
          "mobileNumber",
          "courseDepartment",
          "yearLevel",
          "section",
          "profileYearSectionUpdatedAt",
          "profileMobileUpdatedAt",
          "updatedAt"
        ]);

      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "termsAccepted",
            "termsAcceptedAt",
            "termsVersion",
            "mustChangePassword",
            "passwordChangedAt",
            "updatedAt"
          ]) &&
        request.resource.data.termsAccepted == true &&
        request.resource.data.mustChangePassword == false;

      allow update: if isOwner(userId) &&
        hasOnlyChangedFields([
          "mustChangePassword",
          "passwordChangedAt",
          "updatedAt"
        ]) &&
        request.resource.data.mustChangePassword == false;

      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "mustChangePassword",
            "passwordChangedAt",
            "updatedAt"
          ]) &&
        request.resource.data.mustChangePassword == false;

      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "termsAccepted",
            "termsAcceptedAt",
            "termsVersion",
            "updatedAt"
          ]) &&
        request.resource.data.termsAccepted == true;

      allow update: if isOwner(userId) &&
        hasOnlyChangedFields([
          "termsAccepted",
          "termsAcceptedAt",
          "termsVersion",
          "updatedAt"
        ]) &&
        request.resource.data.termsAccepted == true;

      allow update: if isAdmin() &&
        hasOnlyChangedFields([
          "overdueCount",
          "suspendedUntil",
          "suspensionReason",
          "canBorrow",
          "updatedAt"
        ]);

      // Lets a borrower clear their OWN restriction, but only once it has
      // actually expired, and only to the exact "cleared" values below.
      // They cannot use this to extend, fake, or shorten a suspension, and
      // cannot touch any other user's document (isOwner already enforces that).
      // Requires suspendedUntil to be stored as a real Firestore Timestamp -
      // string dates can't be safely compared against request.time here.
      allow update: if isOwner(userId) &&
        hasOnlyChangedFields([
          "canBorrow",
          "suspendedUntil",
          "suspensionReason",
          "updatedAt"
        ]) &&
        resource.data.canBorrow == false &&
        resource.data.suspendedUntil is timestamp &&
        resource.data.suspendedUntil < request.time &&
        request.resource.data.canBorrow == true &&
        request.resource.data.suspendedUntil == "" &&
        request.resource.data.suspensionReason == "";

      allow delete: if isSuperAdmin();
    }

    /* =========================
       ITEMS
    ========================= */

    match /items/{itemId} {
      allow read: if signedIn();

      allow create: if isAdmin() &&
        adminCanAccessCategory(request.resource.data);

      allow update: if isAdmin() &&
        adminCanAccessCategory(resource.data) &&
        adminCanAccessCategory(request.resource.data);

      allow delete: if isAdmin() &&
        adminCanAccessCategory(resource.data);
    }

    /* =========================
       BORROW REQUESTS
    ========================= */

    match /borrowRequests/{requestId} {
      /*
        Kept broad for now because current pages load full collections
        and filter in React. Strict read rules need query updates first.
      */
      allow read: if signedIn();

      allow create: if isBorrower() &&
        !isBorrowingUnavailable() &&
        request.resource.data.borrowerId == request.auth.uid &&
        request.resource.data.approvalStatus == "Pending" &&
        request.resource.data.actualReturnDate == "" &&
        request.resource.data.assignedAdminId == "" &&
        request.resource.data.approvedBy == "" &&
        request.resource.data.releasedBy == "" &&
        request.resource.data.returnedBy == "" &&
        request.resource.data.returnCondition == "" &&
        request.resource.data.damageLostReport == "" &&
        request.resource.data.keys().hasOnly([
          "itemId",
          "itemCode",
          "itemName",
          "categoryId",
          "categoryName",

          "borrowerId",
          "borrowerEmail",
          "borrowerName",
          "borrowerUserType",
          "borrowerStudentNumber",
          "borrowerEmployeeId",
          "borrowerCourseDepartment",
          "borrowerYearLevel",
          "borrowerSection",
          "borrowerMobileNumber",

          "purpose",
          "borrowDate",
          "expectedReturnDate",
          "actualReturnDate",

          "approvalStatus",

          "assignedAdminId",
          "approvedBy",
          "releasedBy",
          "returnedBy",

          "returnCondition",
          "damageLostReport",

          "createdAt",
          "approvedAt",
          "rejectedAt",
          "releasedAt",
          "returnedAt"
        ]);

      /*
        Admin request actions are blocked only during System Suspension.
        School Closed Today does NOT block Manage Requests because timers continue.
      */
      allow update: if isAdmin() &&
        !isSystemSuspended() &&
        adminCanAccessCategory(resource.data) &&
        adminCanAccessCategory(request.resource.data) &&
        validAdminRequestUpdate();

      /*
        Super Admin extension updates are allowed for:
        - existing closure extension fields
        - new system suspension extension fields
      */
      allow update: if isSuperAdmin() &&
        (
          validClosureExtensionUpdate() ||
          validSystemSuspensionExtensionUpdate()
        );

      allow update: if isBorrower() &&
        resource.data.borrowerId == request.auth.uid &&
        resource.data.approvalStatus == "Pending" &&
        request.resource.data.approvalStatus == "Cancelled" &&
        request.resource.data.cancelledBy == request.auth.uid &&
        hasOnlyChangedFields([
          "approvalStatus",
          "cancelledAt",
          "cancelledBy",
          "updatedAt"
        ]);

      allow update: if isBorrower() &&
        resource.data.borrowerId == request.auth.uid &&
        resource.data.approvalStatus == "Rejected" &&
        request.resource.data.approvalStatus == "Rejected" &&
        request.resource.data.borrowerAcknowledgedBy == request.auth.uid &&
        hasOnlyChangedFields([
          "borrowerAcknowledgedAt",
          "borrowerAcknowledgedBy"
        ]);

      allow delete: if isSuperAdmin();

      function validAdminRequestUpdate() {
        return validApproveUpdate() ||
          validRejectUpdate() ||
          validExpireUpdate() ||
          validReleaseUpdate() ||
          validReturnUpdate();
      }

      function validClosureExtensionUpdate() {
        return resource.data.approvalStatus == "Borrowed" &&
          request.resource.data.approvalStatus == "Borrowed" &&
          hasOnlyChangedFields([
            "expectedReturnDate",
            "originalExpectedReturnDate",
            "closureExtended",
            "closureExtendedDays",
            "lastClosureExtendedDays",
            "closureAdjustedAt",
            "closureAdjustedBy",
            "closureAdjustmentReason",
            "updatedAt"
          ]);
      }

      function validSystemSuspensionExtensionUpdate() {
        return resource.data.approvalStatus == "Borrowed" &&
          request.resource.data.approvalStatus == "Borrowed" &&
          hasOnlyChangedFields([
            "expectedReturnDate",
            "originalExpectedReturnDate",
            "systemSuspensionExtended",
            "systemSuspensionExtendedDays",
            "lastSystemSuspensionExtendedDays",
            "systemSuspensionAdjustedAt",
            "systemSuspensionAdjustedBy",
            "systemSuspensionAdjustmentReason",
            "updatedAt"
          ]);
      }

      function validApproveUpdate() {
        return resource.data.approvalStatus == "Pending" &&
          request.resource.data.approvalStatus == "Approved" &&
          hasOnlyChangedFields([
            "approvalStatus",
            "assignedAdminId",
            "approvedBy",
            "approvedAt",
            "updatedAt"
          ]);
      }

      function validRejectUpdate() {
        return resource.data.approvalStatus == "Pending" &&
          request.resource.data.approvalStatus == "Rejected" &&
          hasOnlyChangedFields([
            "approvalStatus",
            "rejectedAt",
            "rejectReason",
            "autoRejected",
            "updatedAt"
          ]);
      }

      function validExpireUpdate() {
        return resource.data.approvalStatus in ["Pending", "Approved"] &&
          request.resource.data.approvalStatus == "Expired" &&
          hasOnlyChangedFields([
            "approvalStatus",
            "expiredAt",
            "expiredBy",
            "expireReason",
            "autoExpired",
            "updatedAt"
          ]);
      }

      function validReleaseUpdate() {
        return resource.data.approvalStatus == "Approved" &&
          request.resource.data.approvalStatus == "Borrowed" &&
          hasOnlyChangedFields([
            "approvalStatus",
            "borrowDate",
            "expectedReturnDate",
            "releasedBy",
            "releasedAt",
            "updatedAt"
          ]);
      }

      function validReturnUpdate() {
        return resource.data.approvalStatus == "Borrowed" &&
          request.resource.data.approvalStatus == "Returned" &&
          hasOnlyChangedFields([
            "approvalStatus",
            "actualReturnDate",
            "returnCondition",
            "damageLostReport",
            "returnedAt",
            "returnedBy",
            "updatedAt"
          ]);
      }
    }

    /* =========================
       NOTIFICATIONS
    ========================= */

    match /notifications/{notificationId} {
      /*
        Kept broad for now because Notifications.jsx loads all notifications
        then filters them in React.
      */
      allow read: if signedIn();

      allow create: if signedIn() &&
        request.resource.data.status == "Unread" &&
        request.resource.data.keys().hasOnly([
          "userId",
          "targetRole",
          "categoryId",
          "categoryName",
          "title",
          "message",
          "priority",
          "borrowerUserType",
          "status",
          "createdAt",
          "link"
        ]);

      allow update: if signedIn() &&
        validNotificationUpdate();

      allow delete: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isSuperAdmin()
        );

      function validNotificationUpdate() {
        return validOwnNotificationReadUpdate() ||
          validSharedNotificationReadUpdate() ||
          validSharedNotificationDeleteUpdate();
      }

      function validOwnNotificationReadUpdate() {
        return resource.data.userId == request.auth.uid &&
          request.resource.data.status == "Read" &&
          hasOnlyChangedFields([
            "status",
            "readAt"
          ]);
      }

      function validSharedNotificationReadUpdate() {
        return resource.data.userId != request.auth.uid &&
          canReadSharedNotification(resource.data) &&
          hasOnlyChangedFields([
            "readBy",
            "lastReadAt"
          ]);
      }

      function validSharedNotificationDeleteUpdate() {
        return resource.data.userId != request.auth.uid &&
          canReadSharedNotification(resource.data) &&
          hasOnlyChangedFields([
            "deletedBy",
            "deletedAt"
          ]);
      }

      function canReadSharedNotification(data) {
        return isSuperAdmin() ||
          (
            isCategoryAdmin() &&
            data.targetRole in ["categoryAdmin", "admin", "all"] &&
            (
              getCategoryId(data) == "" ||
              getCategoryId(data) in assignedCategories() ||
              getCategoryName(data) in assignedCategories()
            )
          );
      }
    }

    /* =========================
       PENALTY / BORROWER RESTRICTION RECORDS
    ========================= */

    match /penaltyRecords/{penaltyId} {
      allow read: if signedIn() && (
        resource.data.borrowerId == request.auth.uid ||
        isSuperAdmin() ||
        (
          isCategoryAdmin() &&
          adminCanAccessCategory(resource.data)
        )
      );

      allow create: if isAdmin() &&
        adminCanAccessCategory(request.resource.data) &&
        request.resource.data.keys().hasOnly([
          "borrowerId",
          "borrowerName",
          "borrowerEmail",
          "requestId",
          "itemId",
          "itemName",
          "itemCode",
          "categoryId",
          "categoryName",
          "reason",
          "penaltyType",
          "penaltySource",
          "restrictionStartAt",
          "restrictionEndAt",
          "status",
          "createdAt",
          "createdBy",
          "createdByEmail",
          "updatedAt"
        ]);

      allow update: if isAdmin() &&
        adminCanAccessCategory(resource.data) &&
        adminCanAccessCategory(request.resource.data) &&
        hasOnlyChangedFields([
          "status",
          "resolvedAt",
          "resolvedBy",
          "resolvedByEmail",
          "resolutionReason",
          "updatedAt"
        ]);

      allow delete: if isSuperAdmin();
    }

    /* =========================
       CATEGORIES
    ========================= */

    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    /* =========================
       SYSTEM SETTINGS
    ========================= */

    match /systemSettings/{settingId} {
      allow read: if signedIn();

      allow create, update: if isSuperAdmin() &&
        settingId == "schoolStatus" &&
        request.resource.data.keys().hasOnly([
          "isSchoolClosed",
          "closureReason",
          "closedAt",
          "closedBy",
          "closedByName",
          "reopenedAt",
          "reopenedBy",
          "lastClosureExtendedDays",
          "lastClosureExtendedRequests",
          "lastClosureAdjustedAt",

          "isSystemSuspended",
          "systemSuspensionReason",
          "systemSuspendedAt",
          "systemSuspendedBy",
          "systemSuspendedByName",
          "systemResumedAt",
          "systemResumedBy",
          "lastSystemSuspensionExtendedDays",
          "lastSystemSuspensionExtendedRequests",
          "lastSystemSuspensionAdjustedAt",

          "updatedAt"
        ]);

      allow delete: if isSuperAdmin();
    }

    /* =========================
       DEFAULT DENY
    ========================= */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
